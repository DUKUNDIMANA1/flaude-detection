<?xml version="1.0" encoding="utf-8"?>
<!--
  Place this file at:
    android/app/src/main/res/xml/network_security_config.xml

  Then reference it in android/app/src/main/AndroidManifest.xml:
    <application
        android:networkSecurityConfig="@xml/network_security_config"
        ...>

  This allows plain HTTP to your local backend during development.
  Remove or restrict before releasing to production.
-->
<network-security-config>
  <domain-config cleartextTrafficPermitted="true">
    <!-- Allow plain HTTP to any local network address (192.168.x.x, 10.x.x.x) -->
    <domain includeSubdomains="true">192.168.0.0</domain>
    <domain includeSubdomains="true">10.0.0.0</domain>
    <domain includeSubdomains="true">localhost</domain>
    <domain includeSubdomains="true">127.0.0.1</domain>
  </domain-config>
</network-security-config>
